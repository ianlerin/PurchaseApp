@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.AspNetCore.Components
@using PurchaseBlazorApp2.Components.Data
@using PurchaseBlazorApp2.Components.Global
@inject ClientGlobalVar GlobalVar
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Genesis Setup</a>
        <span style="color:white; font-weight:600; font-size:1rem;">@SelectedCompanyName</span>
        <input type="checkbox" class="navbar-toggler" id="navbar-toggle" aria-label="Toggle navigation" />
    </div>
</div>


<div class="nav-scrollable">
    <nav class="flex-column">

        <div class="nav-item px-3 fw-bold">
            <NavLink class="nav-link" href="homepage" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        @if (bIsUserLoaded)
        {
            <div class="nav-item px-3 fw-bold">
                <NavLink class="nav-link d-flex" style="cursor:pointer;"
                         @onclick="() => showPurchase = !showPurchase">
                    <i class="bi @(showPurchase ? "bi-caret-down-fill" : "bi-caret-right-fill") text-primary me-2"></i> 
                    Purchase
                </NavLink>
            </div>
            @if (showPurchase)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="MainList_Client">
                        <span class="bi bi-speedometer2"></span> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="purchaserequisitionrecords_client/create">
                        <span class="bi bi-cart-plus-fill"></span> Create PR
                    </NavLink>
                </div>


                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="supplier-record">
                        <span class="bi bi-person-plus-fill"></span> Add Supplier
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="supplier/list">
                        <span class="bi bi-person-lines-fill"></span> Supplier List
                    </NavLink>
                </div>


            }
            @* ================= HR ================= *@
            @if (bIsHRDepartment)
            {

                <div class="nav-item px-3 fw-bold">
                    <NavLink class="nav-link d-flex  text-nowrap" style="cursor:pointer;"
                       @onclick="() => showHR = !showHR">
                       <i class="bi @(showHR ? "bi-caret-down-fill" : "bi-caret-right-fill") text-success me-2"></i> 
                      Human Resources   
                    </NavLink>
                </div>

              @if (showHR)
              {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="worker-info">
                        <span class="bi bi-person-badge-fill"></span> Add Worker
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="worker">
                        <span class="bi bi-list-nested"></span> Worker Info
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="page-info">
                        <span class="bi bi-cash-stack"></span> Wages
                    </NavLink>
                </div>
              }
            }

            @if (bIsInventoryDepartment)
            {
                <div class="nav-item px-3 fw-bold">
                    <NavLink class="nav-link" style="cursor:pointer;" 
                      @onclick="() => showInventory = !showInventory">
                      <i class="bi @(showInventory ? "bi-caret-down-fill" : "bi-caret-right-fill") text-warning me-2"></i> 
                       Inventory
                    </NavLink>
                </div>
              @if (showInventory)
              {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="inventory-dashboard">
                        <span class="bi bi-speedometer2"></span> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="add-product">
                        <span class="bi bi-person-badge-fill"></span> Add Product
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="add-supplier">
                        <span class="bi bi-person-badge-fill"></span> Add Supplier
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="add-customer">
                        <span class="bi bi-person-badge-fill"></span> AddCustomer
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="add-record">
                        <span class="bi bi-person-badge-fill"></span> Add Record
                    </NavLink>
                </div>
              }
            }
            
        
       }
        <div class="nav-item" style="padding: 0 1rem;">
            <button class="btn btn-danger w-100" @onclick="Logout">
                <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
            </button>
        </div>
    </nav>
</div>

@code {
    bool bIsProcurementManager { get; set; } =false;
    bool bIsManagingDirector { get; set; } = false;
    bool bIsHRDepartment { get; set; } = false;
    bool bIsInventoryDepartment { get; set; } = true;
    bool bIsUserLoaded { get; set; } = false;
    bool showPurchase = false;
    bool showHR = false;
    bool showInventory = false;
    string SelectedCompanyName = "";
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        var company = await GeneralLibrary.GetCurrentCompanyInfo(JS);
        if (!string.IsNullOrEmpty(company?.Name))
            SelectedCompanyName = company.Name;

        // start background loop
        _ = CheckDepartmentLoopAsync(_cts.Token);
        _ = Task.Run(async () =>
       {
           while (!bIsUserLoaded)
           {
               var json = await JS.InvokeAsync<string>("getCookie", "userKey");
               if (!string.IsNullOrWhiteSpace(json))
               {
                   var MyUser = System.Text.Json.JsonSerializer.Deserialize<UserName>(json);
                   if (MyUser != null)
                   {
                       bIsUserLoaded = true;
                   }
               }

               await Task.Delay(2000);
           }


           await InvokeAsync(() =>
       {

           StateHasChanged();
       });
       });
    }

    private async Task CheckDepartmentLoopAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                EDepartment MyDepartment = await GeneralLibrary.GetCurrentDepartmentRole(JS);
                bIsProcurementManager = (MyDepartment == EDepartment.ProcurementManager);
                bIsManagingDirector = (MyDepartment == EDepartment.ManagingDirector);
                EHRRole HRRole = await GeneralLibrary.GetCurrentHRRole(JS);
                bIsHRDepartment = HRRole == EHRRole.Manager;
                // request UI update
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error checking department: {ex.Message}");
            }

            // wait before checking again (e.g. every 10 seconds)
            await Task.Delay(10000, token);
        }
    }

    private void Logout()
    {

        Navigation.NavigateTo("mainlogout");
    }
}