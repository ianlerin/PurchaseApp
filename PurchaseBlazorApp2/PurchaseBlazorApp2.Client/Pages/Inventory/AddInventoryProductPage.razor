@using InventoryRecord
@using Radzen.Blazor
@inject NavigationManager NavigationManager
@page "/add-product/{ID}"
@page "/add-product"
<h3>AddInventoryProductPage</h3>

<div>
    <label class="form-label fw-bold">ID</label>
    <InputText class="form-control"
               @bind-Value="ItemData.ID" readonly />
</div>

<div>
    <label class="form-label fw-bold">Name</label>
    <InputText class="form-control"
               @bind-Value="ItemData.Name" />
</div>

<div>
    <label class="form-label fw-bold">Quantity</label>
    <InputNumber class="form-control" @bind-Value="ItemData.Quantity" readonly />
</div>

<div class="d-flex gap-2 mt-3">
    <button type="submit"
            class="btn btn-primary"
            @onclick="OnSubmitProduct">
        Edit
    </button>

    <button type="button"
            class="btn btn-secondary"
            @onclick="OnRecord">
        Add Record
    </button>
</div>


@if (!string.IsNullOrEmpty(ID))
{
    if (SupplierTabs == null)
    {
        <p>Loading suppliers...</p>
    }
    else if (!SupplierTabs.Any())
    {
        <p>No suppliers have this product yet.</p>
    }
    else
    {
        <div class="tabs mb-3">
            @for (int i = 0; i < SupplierTabs.Count; i++)
            {
                var index = i;
                <button class="tab-button @(ActiveSupplierTabIndex == index ? "active" : "")"
                        @onclick="() => SelectSupplierTab(index)">
                    @SupplierTabs[index].ID
                </button>
            }
        </div>

        <RadzenDataGrid Data="@SelectedSupplierRecords"
                        TItem="InventoryRecordData"
                        AllowSorting="true"
                        Class="shadow-sm border rounded p-3"
                        Style="min-width:600px;">
            <Columns>
                <RadzenDataGridColumn TItem="InventoryRecordData"
                                      Property="SupplierData.Name"
                                      Title="Supplier Name"
                                      Width="200px" />
                <RadzenDataGridColumn TItem="InventoryRecordData"
                                      Property="ItemData.Name"
                                      Title="Product Name"
                                      Width="200px" />
                <RadzenDataGridColumn TItem="InventoryRecordData"
                                      Property="Quantity"
                                      Title="Quantity"
                                      Width="200px" />
                <RadzenDataGridColumn TItem="InventoryRecordData"
                                      Title="Created Date"
                                      Width="200px">
                    <Template Context="data">
                        @data.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </Template>
                </RadzenDataGridColumn>


            </Columns>
        </RadzenDataGrid>
    }
}

<style>
    .tabs {
        display: flex;
        gap: 1rem;
        border-bottom: 1px solid #ccc;
    }

    .tab-button {
        background: none;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-weight: bold;
    }

    .tab-button.active {
        border-bottom: 2px solid blue;
        color: blue;
    }
</style>

@code {
    [Inject]
    private HttpClient Http { get; set; }
    [Inject]
    private IJSRuntime JS { get; set; }
    [Parameter]
    public string ID { get; set; }
    public InventoryItemData? ItemData { get; set; } = new InventoryItemData();
    private List<InventorySupplierData> SupplierTabs;
    private List<InventoryRecordData> SelectedSupplierRecords;
    private int ActiveSupplierTabIndex = 0;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(ID))
        {
            return;
        }

        ItemData.ID = ID;
        var products = await Http.GetFromJsonAsync<List<InventoryItemData>>("api/inventory/get-products");
        var product = products?.FirstOrDefault(p => p.ID == ID);
        if (product != null)
        {
           ItemData.Name = product.Name;
        }

        ItemData.Quantity = await Http.GetFromJsonAsync<int>($"api/inventory/get-quantity?productId={ID}");
        await LoadSuppliers();
    }
    private List<InventoryRecordData> AllRecords = new(); 

    private async Task LoadSuppliers()
    {
 
        AllRecords = await Http.GetFromJsonAsync<List<InventoryRecordData>>($"api/inventory/get-records?productId={ID}");
      
        SupplierTabs = AllRecords
                        .Select(r => r.SupplierData)
                        .GroupBy(s => s.ID)
                        .Select(g => g.First())
                        .ToList();
        ActiveSupplierTabIndex = 0;
        FilterRecordsForActiveTab();
    }

   
    private void FilterRecordsForActiveTab()
    {
        if (SupplierTabs == null || !SupplierTabs.Any())
        {
            SelectedSupplierRecords = new List<InventoryRecordData>();
            return;
        }

        var selectedSupplierId = SupplierTabs[ActiveSupplierTabIndex].ID;
        SelectedSupplierRecords = AllRecords
            .Where(r => r.SupplierData.ID == selectedSupplierId)
            .ToList();
    }

    private void SelectSupplierTab(int index)
    {
        if (index < 0 || index >= SupplierTabs.Count) return;

        ActiveSupplierTabIndex = index;
        FilterRecordsForActiveTab(); 
    }
    private async Task OnSubmitProduct()
    {
        if (string.IsNullOrWhiteSpace(ItemData.Name))
        {
            await JS.InvokeVoidAsync("alert", "Please enter a product name!");
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/inventory/add-product", ItemData);

            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Submit failed! Reason: {msg}");
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<IdResponse>();
            if (result != null) ItemData.ID = result.Id;

            await JS.InvokeVoidAsync("alert", $"SubmitSuccess! Product ID: {ItemData.ID}");


            ItemData = new InventoryItemData();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Submit failed! Exception: {ex.Message}");
        }
    }

    private void OnRecord()
    {
        NavigationManager.NavigateTo($"/add-record?productId={ItemData.ID}");
    }
}
