@using InventoryRecord
@page "/add-supplier"
<h3>Add Supplier</h3>
<div>
    <label class="form-label fw-bold">ID</label>
    <InputText class="form-control"
               @bind-Value="SupplierData.ID" readonly />
</div>

<div>
    <label class="form-label fw-bold">Name</label>
    <InputText class="form-control"
               @bind-Value="SupplierData.Name" />
</div>
<div>
    <label class="form-label fw-bold">Address</label>
    <InputText class="form-control"
               @bind-Value="SupplierData.Address" />
</div>
<div>
    <label class="form-label fw-bold">Contact</label>
    <InputText class="form-control"
               @bind-Value="SupplierData.Contact" />
</div>
<button type="submit"
        class="btn btn-primary btn-lg px-5"
        @onclick="OnSubmitSupplier">
    Edit
</button>

@code {
    [Inject]
    private HttpClient Http { get; set; }
    [Inject]
    private IJSRuntime JS { get; set; }
    public InventorySupplierData SupplierData { get; set; } = new InventorySupplierData();

    private async Task OnSubmitSupplier()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/inventory/add-supplier", SupplierData);

            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Submit failed! Reason: {msg}");
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<IdResponse>();
            if (result != null) SupplierData.ID = result.Id;

            await JS.InvokeVoidAsync("alert", $"SubmitSuccess! Supplier ID: {SupplierData.ID}");

          
            SupplierData.Name = "";
            SupplierData.Address = "";
            SupplierData.Contact = "";
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Submit failed! Exception: {ex.Message}");
        }
    }
}