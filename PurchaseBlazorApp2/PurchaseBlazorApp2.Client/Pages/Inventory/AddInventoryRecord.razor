@page "/add-record"
@using InventoryRecord
@using PurchaseBlazorApp2.Components.Data

<h3>Inventory Record</h3>
@inject HttpClient Http
<EditForm Model="Record" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Item -->
    <div class="mb-3">
        <label class="form-label">Item</label>
        <InputSelect class="form-control" @bind-Value="SelectedItemId">
            <option value="">-- Select Item --</option>
            @foreach (var item in ItemList)
            {
                <option value="@item.ID">@($"{item.Name}")</option>
            }
        </InputSelect>
    </div>

    <!-- Supplier -->
    <div class="mb-3">
        <label class="form-label">Supplier</label>
        <InputSelect class="form-control" @bind-Value="SelectedSupplierId">
            <option value="">-- Select Supplier --</option>
            @foreach (var supplier in SupplierList)
            {
                <option value="@supplier.ID">@($"{supplier.ID}_{supplier.Name}")</option>
            }
        </InputSelect>
    </div>

    <!-- Quantity -->
    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="Record.Quantity" />
    </div>

    <!-- Created -->
    <div class="mb-3">
        <label class="form-label">Created By</label>
        <InputText class="form-control" @bind-Value="Record.CreatedBy" readonly />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>

@code {
    [Inject] IJSRuntime JS { get; set; }

    private string? _selectedItemId;
    private string? SelectedItemId
    {
        get => _selectedItemId;
        set
        {
            _selectedItemId = value;

            if (!string.IsNullOrEmpty(value))
            {
                Record.ItemData.ID = value;
            }
        }
    }

    private string? _selectedSupplierId;
    private string? SelectedSupplierId
    {
        get => _selectedSupplierId;
        set
        {
            _selectedSupplierId = value;

            if (!string.IsNullOrEmpty(value))
            {
                Record.SupplierData.ID = value;
            }
        }
    }

    private List<InventoryItemData> ItemList = new List<InventoryItemData>();

    private List<InventorySupplierData> SupplierList = new List<InventorySupplierData>();


    private InventoryRecordData Record = new InventoryRecordData();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ItemList =
                await Http.GetFromJsonAsync<List<InventoryItemData>>("api/inventory/get-products")
                ?? new();

            SupplierList =
                await Http.GetFromJsonAsync<List<InventorySupplierData>>("api/inventory/get-suppliers")
                ?? new();
        }
        catch
        {
            ItemList = new();
            SupplierList = new();
        }
    }



    protected async override void OnInitialized()
    {
        if(string.IsNullOrEmpty(Record.CreatedBy))
        {
            UserName username = await GeneralLibrary.GetCurrentUser(JS);
            Record.CreatedBy = username.Name;
        }
        
    }
        

    private void OnItemChanged(ChangeEventArgs e)
    {
        SelectedItemId = e.Value?.ToString();
        Record.ItemData = ItemList.FirstOrDefault(x => x.ID == SelectedItemId) ?? new InventoryItemData();
    }

    private void OnSupplierChanged(ChangeEventArgs e)
    {
        SelectedSupplierId = e.Value?.ToString();
        Record.SupplierData = SupplierList.FirstOrDefault(x => x.ID == SelectedSupplierId) ?? new InventorySupplierData();
    }

    private async Task HandleValidSubmit()
    {


        if (string.IsNullOrEmpty(SelectedItemId) || string.IsNullOrEmpty(SelectedSupplierId))
        {
            await JS.InvokeVoidAsync("alert", "Please select Item and Supplier");
            return;
        }
        Record.ItemData = ItemList.FirstOrDefault(x => x.ID == SelectedItemId) ?? new InventoryItemData();
        Record.SupplierData = SupplierList.FirstOrDefault(x => x.ID == SelectedSupplierId) ?? new InventorySupplierData();

        var response = await Http.PostAsJsonAsync("api/inventory/add-record", Record);

        if (response.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "Record saved successfully!");

        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", $"Error: {error}");
        }
    }
}