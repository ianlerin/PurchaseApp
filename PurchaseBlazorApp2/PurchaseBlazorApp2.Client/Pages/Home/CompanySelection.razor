
@page "/company"
@page "/"
@using PurchaseBlazorApp2.Client.Layout
@using PurchaseBlazorApp2.Components.Data
@inject NavigationManager NavigationManager
@layout SimpleLayout
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="d-flex justify-content-center align-items-center vh-100">
    <div>
        <h3 class="text-center">Company Selection</h3>

        <div class="card p-4" style="max-width:400px">
            <div class="mb-3">
                <label class="form-label">Select Company</label>

                <select class="form-select" @bind="SelectedCompanyId">
                    <option value="">-- Select Company --</option>

                    @foreach (var company in Companies)
                    {
                        <option value="@company.ID">@company.Name</option>
                    }
                </select>
            </div>

            <button class="btn btn-primary w-100" @onclick="Proceed">
                Proceed
            </button>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="text-danger mt-2">
                    @ErrorMessage
                </div>
            }
        </div>
    </div>
</div>

@code {

    private List<CompanyInfo> Companies = new();


    private int _selectedCompanyId;
    public int SelectedCompanyId
    {
        get => _selectedCompanyId;
        set
        {
            _selectedCompanyId = value;

            // Update the selected company object automatically
            SelectedCompany = Companies
                .FirstOrDefault(c => c.ID == _selectedCompanyId);
        }
    }




    // Exposed selected object
    private CompanyInfo? SelectedCompany;

    private string ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanies();
    }

    private async Task LoadCompanies()
    {
        try
        {
            int userId = 0;

            int maxAttempts = 20;     // try for ~10 seconds
            int attempt = 0;

            while (userId==0 && attempt < maxAttempts)
            {
                userId = await GeneralLibrary.GetCurrentUserID(JS);

                if (userId==0)
                {
                    await Task.Delay(500); // wait 0.5 seconds before retry
                    attempt++;
                }
            }

            if (userId==0)
            {
                ErrorMessage = "Unable to retrieve user id.";
                return;
            }

            var response = await Http.PostAsJsonAsync(
                "api/login/getavailablecompanies",
                userId
            );

            if (response.IsSuccessStatusCode)
            {   await JS.InvokeVoidAsync("console.error", $"response success");
                Companies = await response.Content
                    .ReadFromJsonAsync<List<CompanyInfo>>()
                    ?? new List<CompanyInfo>();
            }
            else
            {   await JS.InvokeVoidAsync("console.error", $"response error");
                ErrorMessage = "Server returned error.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async void Proceed()
    {
        if (SelectedCompany == null)
        {

            return;
        }

        if (JS != null)
        {
            UserName MyUser = new UserName();
            string userKey = await JS.InvokeAsync<string>("getCookie", "userKey");
            if (!string.IsNullOrWhiteSpace(userKey))
            {
                MyUser = System.Text.Json.JsonSerializer.Deserialize<UserName>(userKey);
            }
            GetRoleRequest Request = new GetRoleRequest();
            Request.UserID = MyUser.ID;
            Request.CompanyId = SelectedCompanyId;
            var roleTask = Http.PostAsJsonAsync(
              NavigationManager.ToAbsoluteUri("api/login/getrole"),
              Request
          );
            var hrroleTask = Http.PostAsJsonAsync(
               NavigationManager.ToAbsoluteUri("api/login/gethrrole"),
               Request
           );

            await Task.WhenAll(hrroleTask, roleTask);
            // --- ROLE ---
            EDepartment departmentRole = EDepartment.NotSpecified;
            try
            {
                var roleResponse = roleTask.Result;
                departmentRole = await roleResponse.Content.ReadFromJsonAsync<EDepartment>();
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("console.error", $"Error retrieving role: {ex.Message}");
            }

            EHRRole HRRole = EHRRole.None;
            try
            {
                var hrroleResponse = hrroleTask.Result;
                HRRole = await hrroleResponse.Content.ReadFromJsonAsync<EHRRole>();
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("console.error", $"Error retrieving role: {ex.Message}");
            }
            MyUser.Role = departmentRole;
            MyUser.Department = departmentRole.ToString();
            MyUser.HRRole = HRRole;
            if (JS != null)
            {
                string jsonUser = System.Text.Json.JsonSerializer.Serialize(MyUser);
                await JS.InvokeVoidAsync("setCookie", "userKey", jsonUser, 1);
            }

            string SelectedCompanyUser = System.Text.Json.JsonSerializer.Serialize(SelectedCompany);
            await JS.InvokeVoidAsync("setCookie", "SelectedCompany", SelectedCompanyUser, 1);
            NavigationManager.NavigateTo("/homepage");
        }

    }

}